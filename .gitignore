# .gitignore

```gitignore
# =========================
# Python
# =========================

__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# Backend
# =========================

backend/.env
backend/venv_linux/

# =========================
# Frontend
# =========================

frontend/.env
frontend/node_modules/

# =========================
# Build outputs
# =========================

build/
dist/

# =========================
# Intel Pin build outputs
# =========================

*.o
*.so
*.out
obj-intel64/

# =========================
# Logs
# =========================

*.log

# =========================
# OS files
# =========================

.DS_Store
Thumbs.db

# =========================
# VSCode
# =========================

.vscode/